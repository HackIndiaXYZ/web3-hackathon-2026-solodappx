{
  "name": "skillchain-contracts",
  "version": "1.0.0",
  "description": "SkillChain smart contracts for Polygon deployment",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "deploy:local": "npx hardhat run scripts/deploy.js --network hardhat",
    "deploy:amoy": "npx hardhat run scripts/deploy.js --network polygonAmoy",
    "deploy:mainnet": "npx hardhat run scripts/deploy.js --network polygon",
    "verify:amoy": "npx hardhat verify --network polygonAmoy",
    "node": "npx hardhat node"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.4",
    "dotenv": "^16.3.1"
  }
}
